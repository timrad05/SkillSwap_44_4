	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" && stylelint \"src/**/*.{css,scss}\"",
		"lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix && stylelint \"src/**/*.{css,scss}\" --fix",
		"lint:ci": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0 && stylelint \"src/**/*.{css,scss}\" --max-warnings=0",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"check": "npm run lint:ci && npm run format:check && npm run build",
		"fix": "npm run lint:fix && npm run format",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test": "jest",
		"test:watch": "jest --watch",
		"prepare": "husky"
	},
	"lint-staged": {
		"src/**/*.{js,jsx,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"src/**/*.{css,scss}": [
			"stylelint --fix --allow-empty-input",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	},
